generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Course {
  id            String     @id @default(cuid())
  titleEn       String
  titleHe       String
  descriptionEn String
  descriptionHe String
  price         Float
  durationMin   Int
  maxParticipants Int     @default(8)
  imageUrl      String?
  color         String     @default("amber")
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  slots         TimeSlot[]
  recipes       Recipe[]
  coupons       Coupon[]
}

model Recipe {
  id            String   @id @default(cuid())
  titleEn       String
  titleHe       String
  descriptionEn String
  descriptionHe String
  ingredientsEn String
  ingredientsHe String
  stepsEn       String
  stepsHe       String
  imageUrl      String?
  color         String   @default("amber")
  active        Boolean  @default(true)
  courseId      String?
  course        Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
}

model TimeSlot {
  id       String    @id @default(cuid())
  courseId String
  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  startsAt DateTime
  endsAt   DateTime
  capacity Int       @default(1)
  bookings Booking[]
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  courseId      String?
  course        Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model Booking {
  id             String   @id @default(cuid())
  slotId         String
  slot           TimeSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  email          String?
  status         String   @default("confirmed")
  couponId       String?
  coupon         Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode     String?
  originalPrice  Float?
  finalPrice     Float?
  discountAmount Float?
  createdAt      DateTime @default(now())
}

model AboutContent {
  id           String   @id @default("default")
  titleEn      String
  titleHe      String
  introEn      String
  introHe      String
  paragraphsEn Json
  paragraphsHe Json
  updatedAt    DateTime @updatedAt
}

model GalleryOrder {
  id        String   @id @default("default")
  keys      Json
  updatedAt DateTime @updatedAt
}
